# Managed By
#   This file is managed by ~/.dotfiles and linked to ~/.gitconfig.
#
# Loaded As
#   Global Git config.
#
# Local Overrides
#   Machine-local path settings are included from:
#     ~/.config/dotfiles/git/root.local.ini
#   Machine-local identity and signing settings are included from:
#     ~/.config/dotfiles/git/personal.local.ini
#
# Notes
#   Do not commit personal identity, signing keys, or machine-specific paths
#   into this repo-managed file.

[init]
	defaultBranch = main
	templateDir = ~/.dotfiles/git
[pager]
	branch = false
	diff = diff-so-fancy | less --tabs=2 -RFX
[core]
	editor = vim
	autocrlf = input
	hooksPath = ~/.dotfiles/git/hooks
	ignorecase = false
	quotepath = false
[commit]
	template = ~/.dotfiles/git/templates/gitmessage
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[diff]
	tool = code
[difftool "code"]
	cmd = code --wait --diff $LOCAL $REMOTE
[merge]
	tool = code
[mergetool "code"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
[interactive]
	diffFilter = diff-so-fancy --patch
[include]
	path = ~/.config/dotfiles/git/root.local.ini
[include]
	path = ~/.config/dotfiles/git/personal.local.ini

[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red
	oldHighlight = red bold 254
	newNormal = green
  newHighlight = green bold 254
[diff-so-fancy]
	markEmptyLines = false
